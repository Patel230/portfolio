{
  "name": "lakshman-patel-portfolio",
  "version": "0.2.0",
  "buildDate": "June 8, 2026",
  "description": "Full Stack Developer & AI Engineer Portfolio - Vue.js, TypeScript, Python, FastAPI, Neo4j - Creator of GraphDone & TaskDone",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "fetch-github-stats": "node scripts/fetch-github-stats.mjs",
    "prebuild": "node scripts/fetch-github-stats.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
